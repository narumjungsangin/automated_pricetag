{
  "name": "automated-pricetag",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win dir",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  },
  "build": {
    "appId": "com.pharmacy.pricetag",
    "productName": "약국 가격표 생성기",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  }
}
